<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Data | About</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="scanlines"></div>
  
  <%- include('partials/navbar', { activePage: 'about' }) %>

  <div class="dashboard-wrapper">
    <div class="hud-container slide-in">
      <div class="hud-header">
        <span class="hud-blinker"></span>
        <span class="hud-title">DATA.RETRIEVAL: /about</span>
      </div>
      
      <div class="hud-content">
        <h2 class="panel-title">> STUDENT PROFILE RECORD</h2>
        
        <div class="data-pad">
          <div class="data-row">
            <span class="data-label">NAME</span>
            <span class="data-value highlight"><%= name %></span>
          </div>
          <div class="data-row">
            <span class="data-label">ROLL NO</span>
            <span class="data-value highlight-secondary"><%= rollNo %></span>
          </div>
          <div class="data-row">
            <span class="data-label">COURSE</span>
            <span class="data-value highlight-tertiary"><%= course %></span>
          </div>
        </div>

        <a href="/" class="cyber-btn mt-4">← RETURN TO CORE</a>
      </div>
    </div>
  </div>
</body>
</html>
