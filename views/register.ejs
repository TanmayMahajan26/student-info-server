<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Data | Register</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="scanlines"></div>
  
  <%- include('partials/navbar', { activePage: 'register' }) %>

  <div class="dashboard-wrapper">
    <div class="hud-container slide-in">
      <div class="hud-header">
        <span class="hud-blinker"></span>
        <span class="hud-title">SYSTEM.REGISTER_NODE</span>
      </div>
      
      <div class="hud-content">
        <h1 class="glitch-text" data-text="REGISTER FILE">REGISTER FILE</h1>
        <p class="cyber-subtitle">> Input new entity into the database construct.</p>

        <form action="/register" method="POST" class="cyber-form mt-4">
          <div class="tech-card" style="display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; max-width: 400px; padding: 2rem;">
            
            <div style="width: 100%;">
              <label class="tech-label" style="display: block; margin-bottom: 0.5rem; color: #ffeb3b;">ROLL NUMBER</label>
              <input type="text" name="roll" class="cyber-btn" style="width: 100%; border: 1px solid #11ff11; outline: none; background: rgba(0,20,0,0.8); color: #11ff11;" required />
            </div>

            <div style="width: 100%;">
              <label class="tech-label" style="display: block; margin-bottom: 0.5rem; color: #ffeb3b;">STUDENT NAME</label>
              <input type="text" name="name" class="cyber-btn" style="width: 100%; border: 1px solid #11ff11; outline: none; background: rgba(0,20,0,0.8); color: #11ff11;" required />
            </div>

            <div style="width: 100%;">
              <label class="tech-label" style="display: block; margin-bottom: 0.5rem; color: #ffeb3b;">BRANCH</label>
              <select name="branch" class="cyber-btn" style="width: 100%; border: 1px solid #11ff11; outline: none; background: rgba(0,20,0,0.8); color: #11ff11;" required>
                <option value="Computer Engineering">Computer Engineering</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Electronics & Computer Science">Electronics & Computer Science</option>
                <option value="AI & Data Science">AI & Data Science</option>
                <option value="Mechanical Engineering">Mechanical Engineering</option>
              </select>
            </div>

            <div style="width: 100%;">
              <label class="tech-label" style="display: block; margin-bottom: 0.5rem; color: #ffeb3b;">YEAR</label>
              <select name="year" class="cyber-btn" style="width: 100%; border: 1px solid #11ff11; outline: none; background: rgba(0,20,0,0.8); color: #11ff11;" required>
                <option value="First Year (FE)">First Year (FE)</option>
                <option value="Second Year (SE)">Second Year (SE)</option>
                <option value="Third Year (TE)">Third Year (TE)</option>
                <option value="Final Year (BE)">Final Year (BE)</option>
              </select>
            </div>

            <button type="submit" class="cyber-btn primary mt-2" style="width: 100%; justify-content: center;">SUBMIT FILE (POST)</button>
          </div>
        </form>

        <div style="margin-top: 2rem;">
          <a href="/" class="cyber-btn mt-4">← RETURN TO CORE</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
